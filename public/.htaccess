<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # 1. Force Lowercase URLs (Optional but recommended for consistency)
  # This requires Map functionality which might not be on all shared hosts.
  # If it fails, we can skip it, but let's try the trailing slash fix first.

  # 1. Handle spaces and %20 in URLs (Redirect to hyphenated version)
  RewriteCond %{REQUEST_URI} ^(.*)(\s|%20)(.*)$
  RewriteRule ^ %1-%3 [L,R=301]

  # 2. Remove trailing slashes from all URLs (except directories)
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_URI} (.+)/$
  RewriteRule ^ %1 [L,R=301]

  # 3. Serve sitemap via PHP proxy (keeps URL as pbtadka.com/sitemap.xml)
  RewriteRule ^sitemap\.xml$ sitemap-proxy.php [L]

  # 4. Standard React SPA Routing
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
